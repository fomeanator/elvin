# Local Unity sandbox / test harness. The EXPORT TEMPLATE skeleton is
# committed (Boot.cs + asmdef, ProjectSettings, Packages manifest, UI theme)
# so /v1/export works from any fresh clone; everything else stays local.
/sandbox/*
!/sandbox/Packages/
/sandbox/Packages/*
!/sandbox/Packages/manifest.json
!/sandbox/ProjectSettings/
!/sandbox/Assets/
/sandbox/Assets/*
!/sandbox/Assets/Sandbox/
!/sandbox/Assets/Sandbox.meta
!/sandbox/Assets/Resources/
!/sandbox/Assets/Resources.meta

# Stray screenshots
Screenshot*.png
*_demo.png

# Release build artifacts
/dist/

# Runtime player saves written by the server's /v1/state (per-user state mirror)
server/content/state/
