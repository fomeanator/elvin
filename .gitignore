# Local Unity sandbox / test harness. The EXPORT TEMPLATE skeleton is
# committed (Boot.cs + asmdef, ProjectSettings, Packages manifest, UI theme)
# so /v1/export works from any fresh clone; everything else stays local.
/sandbox/*
!/sandbox/Packages/
/sandbox/Packages/*
!/sandbox/Packages/manifest.json
!/sandbox/ProjectSettings/
!/sandbox/Assets/
/sandbox/Assets/*
!/sandbox/Assets/Sandbox/
!/sandbox/Assets/Sandbox.meta
!/sandbox/Assets/Resources/
!/sandbox/Assets/Resources.meta
!/sandbox/Assets/Icon/
!/sandbox/Assets/Icon.meta
!/sandbox/Assets/Editor/
!/sandbox/Assets/Editor.meta

# Stray screenshots
Screenshot*.png
*_demo.png

# Release build artifacts
/dist/

# Runtime player saves written by the server's /v1/state (per-user state mirror)
server/content/state/
panel/public/docs/content/
server/website/docs/
server/content/.cache/

# On-demand ASTC transcodes (server/astc.go) — generated next to their PNG/JPG
# source on first request, regenerable any time astcenc is on PATH; never a
# thing to commit (a re-uploaded source would leave a stale sidecar behind).
*.astc

# On-demand downscaled texture variants (server/downscale.go) — generated next
# to their full-size source on first request; same regenerable-sidecar rule.
*@2k.png
*@2k.jpg
*@2k.jpeg

# On-demand KTX2/BasisU encodes (server/ktx2.go) — same regenerable-sidecar rule.
*.ktx2

# Licensed heroine art pack — LOCAL TESTING ONLY, never publish (dist/Перс.rar)
server/content/sprites/hill/

# bundle import sources (licensed art, ~1GB) and runtime version history
content/cold/
server/content/.history/

# Demo content lives in its own repo (lvn-demo-content); fetch with
# scripts/fetch-demo-content.sh. The engine repo is code only. (Anchored:
# panel/public/play/content — the playground's tiny demo pack — stays tracked.)
/server/content/
/content/

# OS noise and local build outputs
.DS_Store
/dist/

# Deploy/build artifacts — regenerated, never hand-edited:
# server/website is `npm run deploy` output of the Studio app;
# lvns.wasm copies are built from tools/lvnconv/wasm (panel npm scripts / pages.yml).
/server/website/
panel/public/lvns.wasm
panel/public/play/lvns.wasm
